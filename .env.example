# ─────────────────────────────────────────────
#  Employee Attendance System — Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# App environment: development | production
# Set to production when deploying with HTTPS
APP_ENV=development

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=employee_attendance

# ── Admin (used only on first run if no admin exists) ──
# After /setup wizard completes, these are ignored.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@123

# ── Office GPS (for attendance scanning radius) ───────
OFFICE_LAT=17.494664737165042
OFFICE_LON=78.40496618113566

# ── SMTP Email ────────────────────────────────
# You can also configure this inside Admin → Email Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=HR Department
SMTP_FROM_EMAIL=hr@yourcompany.com
