# ─────────────────────────────────────────────
#  Employee Attendance System — Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# App environment: development | production
# Set to production when deploying with HTTPS
APP_ENV=development

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=employee_attendance

# ── Admin (used only on first run if no admin exists) ──
# After /setup wizard completes, these are ignored.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@123

# ── Office GPS (for attendance scanning radius) ───────
OFFICE_LAT=17.494664737165042
OFFICE_LON=78.40496618113566

# ── SMTP Email ────────────────────────────────
# You can also configure this inside Admin → Email Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=HR Department
SMTP_FROM_EMAIL=hr@yourcompany.com

# ── Multi-tenancy ─────────────────────────────
# Leave blank for single-tenant (default) mode.
# In multi-tenant mode a separate "att_master" database is used for the tenant
# registry.  The same DB_HOST/USER/PASS credentials are used to connect to it.

# ── Redis (for distributed rate-limiting) ─────
# Leave blank (or "memory://") to use in-process memory (single-server only).
# Example for Redis: REDIS_URL=redis://localhost:6379/0
REDIS_URL=memory://

# ── PII Encryption ────────────────────────────
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to store PII fields as plaintext (backward-compatible).
ENCRYPTION_KEY=
