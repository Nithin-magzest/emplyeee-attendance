# Flask session signing key. Required in production — without it sessions
# regenerate (logging everyone out) on every container restart/redeploy.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Encrypts PII fields (Aadhar/PAN/bank account) at rest. If unset, these
# fields are stored in PLAINTEXT with no warning — set this before going live.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here

APP_ENV=production

# Organisation self-registration (SECURITY)
# Set this to a strong random string to allow /create_org to work.
# If left empty or unset, the /create_org endpoint is DISABLED entirely.
# Share this code only with people authorised to create new organisations.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SIGNUP_SECRET=

# Database
# Local dev: DB_HOST=localhost (or DB_HOST=db when using plain compose.yaml)
# Production: DB_HOST=<RDS endpoint from `terraform output rds_endpoint`>; DB_USER/DB_PASS
# must match db_username/db_password in terraform/terraform.tfvars
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_db_password
DB_NAME=employee_attendance

# DB connection hardening (all optional — sensible defaults if unset)
# sslmode=prefer encrypts when the server supports it (RDS always does) but
# won't break local Postgres installs that have no SSL cert configured.
# Set to "require" or "verify-full" for a stricter production posture.
DB_SSLMODE=prefer
# DB_SSLROOTCERT=/path/to/rds-ca-bundle.pem   # only needed for verify-full
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000

# Admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# Office GPS location — used for geofenced check-in. Set to your office's
# actual coordinates (e.g. from Google Maps: right-click your location).
OFFICE_LAT=0.0
OFFICE_LON=0.0

# Public base URL — used when building links in email (password reset, offer
# letters). Must NOT end with a slash. If unset, Flask falls back to the
# Host request header, which can be spoofed. Always set this in production.
# Example: APP_URL=https://attendance.yourdomain.com
APP_URL=

# CORS — REQUIRED in production.
# Set to your frontend domain(s), comma-separated.
# If left empty in production the app will deny all cross-origin /api/* requests.
# Wildcard (*) is only acceptable for local dev; never use it in production.
# Example: ALLOWED_ORIGINS=https://attendance.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Rate limiter backend (optional but strongly recommended for production)
# Without this, each gunicorn worker keeps its own counter — 4 workers means
# 4x the allowed attempts before a limit kicks in. Redis makes it shared.
# Install: sudo apt install redis-server && sudo systemctl enable --now redis
# Then set: REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=

# Malware scanning (ClamAV) for employee document/photo uploads.
# compose.yaml sets these to clamav:3310 automatically for the containerized
# stack. For local dev without Podman, point at a locally running clamd, or
# leave unset — uploads fail closed (rejected) unless APP_ENV=development,
# in which case a missing/unreachable scanner just logs a warning.
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=Attendance System
SMTP_FROM_EMAIL=your_email@domain.com

# Real-time security alerts (Slack/Discord webhook) — optional. Fires on
# ERROR-severity security events only: account lockouts, malware
# detections, injection-shaped login attempts, privilege-escalation
# attempts. Leave SECURITY_ALERT_WEBHOOK_URL unset to disable entirely —
# every call site checks it and no-ops silently if absent.
# SECURITY_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Employee AI chat assistant (utils/ai_assistant.py) — optional. Leave unset
# to disable the chat widget entirely; the endpoint then returns a friendly
# "not configured" message instead of erroring.
# ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Turnstile — CAPTCHA challenge on /admin_login after 2 failed
# attempts against the same identifier (utils/auth.py). Optional: leave both
# unset to disable the CAPTCHA gate entirely (the 5-strikes/15-minute lockout
# still applies either way). Get keys from the Cloudflare dashboard.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# SECURITY_ALERT_PLATFORM=discord
# SECURITY_ALERT_SIGNING_SECRET=
