aws_region             = "ap-south-1"
vpc_id                 = "vpc-xxxxxxxx"
subnet_ids             = ["subnet-aaaaaaa", "subnet-bbbbbbb"]
ec2_security_group_id  = "sg-xxxxxxxx"
ec2_instance_id        = "i-xxxxxxxxxxxxxxxxx"
alert_email            = "you@example.com"

# IPs allowed to reach SSH/RDP/direct-DB/alternate-HTTP ports on the app
# server. Use your actual office/home/VPN IP(s) — never 0.0.0.0/0 here, that
# would defeat the point of filtering these ports.
trusted_admin_cidrs    = ["203.0.113.42/32"]

# Do NOT put the real db_password here if this file is ever committed.
# Prefer: export TF_VAR_db_password="..." instead, or copy this file to
# terraform.tfvars (already gitignored) and fill it in there.
# db_password = "..."

# ── Firewall opt-ins (all default to [] / "" — provisioned but inert until
# you set these deliberately) ────────────────────────────────────────────

# Network ACL (network_acl.tf) — the EC2 instance's own subnet. Find it via
# the EC2 console (instance -> Networking tab -> Subnet ID) or:
#   aws ec2 describe-instances --instance-ids $EC2_INSTANCE_ID \
#     --query "Reservations[0].Instances[0].SubnetId" --output text
# A NACL applies to EVERYTHING in the subnet, not just this app — confirm
# nothing else important shares it before setting this.
# app_subnet_ids = ["subnet-aaaaaaa"]

# AWS Network Firewall (network_firewall.tf) — a SEPARATE subnet from the
# app's own, dedicated to firewall endpoints (AWS requirement, not a
# preference). Setting this alone does NOT put traffic through the
# firewall — see network_firewall.tf's header comment on route tables.
# Real ongoing cost (~$285/mo+) starts accruing once applied.
# firewall_subnet_ids = ["subnet-ccccccc"]

# WAF/CloudFront (security_hardening.tf) — the EC2 instance's public
# DNS name, which becomes CloudFront's origin. Setting this is a REAL
# architecture change: DNS should point at the CloudFront domain
# afterward, not the EC2 IP directly, and CloudFront becomes the new TLS
# termination point. Plan the DNS cutover before setting this, don't set
# it as a drive-by default.
# app_origin_domain = "ec2-x-x-x-x.ap-south-1.compute.amazonaws.com"
